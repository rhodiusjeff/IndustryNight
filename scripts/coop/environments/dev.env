#!/bin/bash
# dev.env — Development environment configuration
#
# Sourced by config.sh via load_environment "dev"
# These values override the shared defaults in config.sh.

ENV_NAME="dev"
ENV_LABEL="development"

# ---- EKS ----
EKS_CLUSTER="industrynight-dev"
EKS_NODEGROUP="standard-workers-dev"
EKS_DESIRED_CAPACITY=1
EKS_MIN_SIZE=1
EKS_MAX_SIZE=2

# ---- RDS ----
RDS_INSTANCE="industrynight-db-dev"
RDS_SUBNET_GROUP="industrynight-db-subnet-dev"

# ---- Kubernetes ----
K8S_NAMESPACE="industrynight-dev"
K8S_HPA_MIN=1
K8S_HPA_MAX=2

# ---- S3 ----
S3_ASSETS_BUCKET="industrynight-assets-dev"
S3_WEB_BUCKET="industrynight-web-admin-dev"

# ---- Secrets Manager ----
SECRETS_ID="industrynight/database-dev"

# ---- ECR Tag ----
ECR_IMAGE_TAG="dev"

# ---- DNS / Domains ----
API_HOST="dev-api.industrynight.net"
ADMIN_HOST="dev-admin.industrynight.net"
CF_API_RECORD_NAME="dev-api.industrynight.net"
CF_ADMIN_RECORD_NAME="dev-admin.industrynight.net"

# ---- CloudFront ----
CF_DISTRIBUTION_ID="E3QLL0MEWOQRQL"

# ---- CORS ----
CORS_ORIGINS="https://dev-admin.industrynight.net,http://localhost:3000,http://localhost:8080"

# ---- Backups ----
BACKUPS_SUBDIR="dev"

# ---- CloudWatch Logging ----
CW_LOG_TYPES="api,audit"

# ---- Feature Flags ----
ENABLE_MAGIC_TEST_PREFIX="true"

# ---- Smoke Test ----
# Magic-prefix phone for dev smoke check (no Twilio needed — ENABLE_MAGIC_TEST_PREFIX is true in dev)
SMOKE_TEST_PHONE="+15555550199"
