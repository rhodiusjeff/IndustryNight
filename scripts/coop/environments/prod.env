#!/bin/bash
# prod.env — Production environment configuration
#
# Sourced by config.sh via load_environment "prod"
# These values override the shared defaults in config.sh.

ENV_NAME="prod"
ENV_LABEL="production"

# ---- EKS ----
EKS_CLUSTER="industrynight-prod"
EKS_NODEGROUP="standard-workers-v2"
EKS_DESIRED_CAPACITY=2
EKS_MIN_SIZE=1
EKS_MAX_SIZE=4

# ---- RDS ----
RDS_INSTANCE="industrynight-db"
RDS_SUBNET_GROUP="industrynight-db-subnet"

# ---- Kubernetes ----
K8S_NAMESPACE="industrynight"
K8S_HPA_MIN=2
K8S_HPA_MAX=10

# ---- S3 ----
S3_ASSETS_BUCKET="industrynight-assets-prod"
S3_WEB_BUCKET="industrynight-web-admin"

# ---- Secrets Manager ----
SECRETS_ID="industrynight/database"

# ---- ECR Tag ----
ECR_IMAGE_TAG="latest"

# ---- DNS / Domains ----
API_HOST="api.industrynight.net"
ADMIN_HOST="admin.industrynight.net"
CF_API_RECORD_NAME="api.industrynight.net"
CF_ADMIN_RECORD_NAME="admin.industrynight.net"

# ---- CloudFront ----
CF_DISTRIBUTION_ID="E196TNDGV555BI"

# ---- CORS ----
CORS_ORIGINS="https://admin.industrynight.net,http://localhost:3000,http://localhost:8080"

# ---- Backups ----
BACKUPS_SUBDIR="prod"

# ---- CloudWatch Logging ----
CW_LOG_TYPES="api,audit,authenticator,controllerManager,scheduler"

# ---- Feature Flags ----
ENABLE_MAGIC_TEST_PREFIX="false"
